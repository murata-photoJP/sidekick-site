{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "sidekick-lab.com" }],
      "destination": "https://www.sidekick-lab.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "sidekick-site-tawny.vercel.app" }],
      "destination": "https://www.sidekick-lab.com/$1",
      "permanent": true
    }
  ]
}
